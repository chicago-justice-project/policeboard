# Application environment and PostgreSQL client library for the `pg` gem.
# On AL2023, postgresql is installed directly via dnf (no amazon-linux-extras).
option_settings:
  aws:elasticbeanstalk:application:environment:
    LOGGING: debug
    RAILS_SKIP_MIGRATIONS: "true"

packages:
  dnf:
    git: []
    patch: []
    libpq-devel: []
    postgresql15: []
