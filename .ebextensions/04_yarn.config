# Node.js + Yarn for asset precompilation.
# AL2023 ships Node 20+ as an OS package; enable corepack for yarn.
commands:
  01_node_install:
    command: sudo dnf -y install nodejs
    test: '[ ! -x /usr/bin/node ]'

  02_enable_corepack:
    command: sudo corepack enable
    test: '[ ! -x /usr/local/bin/yarn ] && [ ! -x /usr/bin/yarn ]'

container_commands:
  01_yarn_install:
    command: yarn install --frozen-lockfile
